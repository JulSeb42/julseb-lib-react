{
    "name": "tsx-lib-v9",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --open",
        "build": "tsc -b && vite build",
        "lint": "./node_modules/.bin/eslint",
        "preview": "vite preview",
        "cy": "cypress",
        "cy:open": "cypress open",
        "cy:ct:run": "cypress run --component --browser electron",
        "cy:ct:open": "cypress open --component --browser electron",
        "plop": "plop --plopfile 'plop/plopfile.js'",
        "plop:c": "yarn plop component",
        "plop:p": "yarn plop preview",
        "docgen": "react-docgen -o ./src/data/docgen.json ./src/lib/components/**/*.tsx"
    },
    "dependencies": {
        "classnames": "^2.5.1",
        "fuse.js": "^7.0.0",
        "markdown-to-jsx": "^7.4.7",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet": "^6.1.0",
        "react-inlinesvg": "^4.1.3",
        "react-router-dom": "^6.24.1",
        "react-syntax-highlighter": "^15.5.0",
        "styled-components": "^6.1.11",
        "ts-utils-julseb": "^2.3.5"
    },
    "devDependencies": {
        "@eslint/compat": "^1.1.0",
        "@eslint/js": "^9.6.0",
        "@react-docgen/cli": "^2.0.3",
        "@types/jest": "^29.5.12",
        "@types/mocha": "^10.0.7",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@types/react-helmet": "^6.1.11",
        "@types/react-inlinesvg": "^1.0.0",
        "@types/react-router-dom": "^5.3.3",
        "@types/styled-components": "^5.1.34",
        "@vitejs/plugin-react": "^4.3.1",
        "axios": "^1.7.2",
        "cypress": "^13.13.0",
        "eslint": "^9.6.0",
        "eslint-plugin-react": "^7.34.3",
        "globals": "^15.8.0",
        "plop": "^4.0.1",
        "typescript": "^5.5.3",
        "typescript-eslint": "^7.16.0",
        "vite": "^5.3.3",
        "vite-plugin-dts": "^3.9.1"
    }
}
