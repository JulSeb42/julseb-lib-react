{
    "name": "tsx-lib-v9",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "scripts": {
        "dev": "vite --open",
        "build": "tsc -b && vite build",
        "lint": "./node_modules/.bin/eslint",
        "preview": "vite preview",
        "cy": "cypress",
        "cy:open": "cypress open",
        "cy:ct:run": "cypress run --component --browser electron",
        "cy:ct:open": "cypress open --component --browser electron",
        "plop": "plop --plopfile 'plop/plopfile.js'",
        "plop:c": "yarn run plop component",
        "plop:p": "yarn plop preview",
        "docgen": "react-docgen -o ./src/data/docgen.json ./src/lib/components/**/*.tsx"
    },
    "dependencies": {
        "classnames": "^2.5.1",
        "fuse.js": "^7.0.0",
        "markdown-to-jsx": "^7.4.7",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet-async": "^2.0.5",
        "react-inlinesvg": "^4.1.3",
        "react-router-dom": "^6.24.1",
        "react-syntax-highlighter": "^15.5.0",
        "styled-components": "^6.1.11",
        "ts-utils-julseb": "2.4.1"
    },
    "devDependencies": {
        "@eslint/compat": "^1.1.0",
        "@eslint/js": "^9.6.0",
        "@react-docgen/cli": "^2.0.3",
        "@types/jest": "^29.5.12",
        "@types/mocha": "^10.0.7",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@types/react-inlinesvg": "^1.0.0",
        "@types/react-router-dom": "^5.3.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@types/styled-components": "^5.1.34",
        "@vitejs/plugin-react": "^4.3.1",
        "axios": "^1.7.2",
        "cypress": "^13.13.0",
        "eslint": "^9.6.0",
        "eslint-plugin-react": "^7.34.3",
        "globals": "^15.8.0",
        "plop": "^4.0.1",
        "typescript": "^5.5.3",
        "typescript-eslint": "^7.16.0",
        "vite": "^5.3.3",
        "vite-plugin-dts": "^3.9.1"
    },
    "resolutions": {
        "inquirer": "9.3.5"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/tsx-library-julseb.umd.js",
    "module": "./dist/tsx-library-julseb.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/tsx-library-julseb.es.js",
            "require": "./dist/tsx-library-julseb.umd.js",
            "types": "./dist/index.d.ts",
            "default": "./dist/tsx-library-julseb.cjs.js"
        },
        "./index.css": {
            "import": "./dist/index.css",
            "require": "./dist/index.css",
            "default": "./dist/index.css"
        },
        "./types": {
            "import": "./dist/types/index.d.ts",
            "require": "./dist/types/index.d.ts",
            "types": "./dist/types/index.d.ts",
            "default": "./dist/types/index.d.ts"
        },
        "./component-props": {
            "import": "./dist/types/components-props.d.ts",
            "require": "./dist/types/components-props.d.ts",
            "types": "./dist/types/components-props.d.ts",
            "default": "./dist/types/components-props.d.ts"
        }
    },
    "typesVersions": {
        "*": {
            "types": [
                "./dist/lib/types/index.d.ts"
            ]
        }
    }
}
