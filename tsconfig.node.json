{
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "noEmit": true,
        "declaration": true,
        "verbatimModuleSyntax": true,

        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable",
            "ES2021",
            "ESNext",
            "ES2021.String"
        ]
    },
    "include": ["vite.config.ts"]
}
